# ====================================================
# GyaanaSetu – Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!
# ====================================================

# Firebase Web SDK Config (get from Firebase Console > Project Settings)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Your deployed Cloud Function base URL
# Example: https://asia-south1-gyanasetu.cloudfunctions.net
VITE_CLOUD_FUNCTIONS_BASE_URL=

# School config
VITE_SCHOOL_NAME=Sri Kumaran Public School
VITE_GCS_BUCKET=gyanasetu-ncert
